<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.android.purebilibili">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <!-- 🔋 WakeLock 权限 (防止息屏时 CPU 休眠导致音频停止) -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- 🔐 存储权限 (仅 Android 9 及以下需要，用于保存图片到相册) -->
    <uses-permission 
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <!-- 📺 DLNA 投屏所需网络权限 -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE"/>
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE"/>
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE"/>
    <!-- Android 12+ 本地网络发现需要的权限 -->
    <uses-permission android:name="android.permission.NEARBY_WIFI_DEVICES" 
        android:usesPermissionFlags="neverForLocation"
        tools:targetApi="s" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="false" />

    <application
        android:name=".app.PureApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher_bilipai"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_bilipai_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PureBiliBili"
        android:usesCleartextTraffic="true"
        android:localeConfig="@xml/locales_config"
        android:networkSecurityConfig="@xml/network_security_config"
        android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|mnc|colorMode|density"
        android:enableOnBackInvokedCallback="true"
        tools:targetApi="31">

        <!-- 📺 DLNA Cling Service (JitPack/Cling)
             通过 manifestPlaceholders 支持发布时快速回滚到主进程 -->
        <service
            android:name="org.fourthline.cling.android.AndroidUpnpServiceImpl"
            android:process="${castServiceProcess}" />

        <service
            android:name=".feature.cast.CastBridgeService"
            android:exported="false"
            android:process="${castServiceProcess}" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:enabled="true"
            android:theme="@style/Theme.PureBiliBili"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|mnc|colorMode|density|smallestScreenSize|uiMode"
            android:supportsPictureInPicture="true">
            <!-- 🔗 Deep Link: Video (/video/) -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="www.bilibili.com" android:pathPrefix="/video/" />
                <data android:scheme="https" android:host="bilibili.com" android:pathPrefix="/video/" />
                <data android:scheme="https" android:host="m.bilibili.com" android:pathPrefix="/video/" />
                <data android:scheme="http" android:host="www.bilibili.com" android:pathPrefix="/video/" />
                <data android:scheme="http" android:host="bilibili.com" android:pathPrefix="/video/" />
                <data android:scheme="http" android:host="m.bilibili.com" android:pathPrefix="/video/" />
            </intent-filter>

            <!-- 🔗 Deep Link: Live -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="live.bilibili.com" />
                <data android:scheme="http" android:host="live.bilibili.com" />
            </intent-filter>

            <!-- 🔗 Deep Link: Space -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="space.bilibili.com" />
                <data android:scheme="http" android:host="space.bilibili.com" />
            </intent-filter>

            <!-- 🔗 Deep Link: Dynamic -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="t.bilibili.com" />
                <data android:scheme="http" android:host="t.bilibili.com" />
            </intent-filter>
            
            <!-- 🔗 Deep Link: Generic (Catch-all for homepage etc) -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="www.bilibili.com" />
                <data android:scheme="https" android:host="bilibili.com" />
                <data android:scheme="https" android:host="m.bilibili.com" />
                <data android:scheme="http" android:host="www.bilibili.com" />
                <data android:scheme="http" android:host="bilibili.com" />
                <data android:scheme="http" android:host="m.bilibili.com" />
            </intent-filter>
            
            <!-- 🔗 Deep Link: b23.tv 短链接 -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="b23.tv" />
                <data android:scheme="http" android:host="b23.tv" />
            </intent-filter>

            <!-- 🔗 Deep Link: bilibili:// 与 bili://（用于“打开方式”选择） -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="bilibili" />
                <data android:scheme="bili" />
            </intent-filter>
            
            <!-- 📤 分享文本意图 (用户分享链接文本到 BiliPai) -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
            
            <!-- 🚀 App Shortcuts Deep Links -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="bilipai" />
            </intent-filter>

            <!-- 🔌 Plugin Install Links -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="bilipai.app" android:pathPrefix="/plugin/install" />
                <data android:scheme="https" android:host="bilipai.app" android:pathPrefix="/plugins/install" />
                <data android:scheme="https" android:host="www.bilipai.app" android:pathPrefix="/plugin/install" />
                <data android:scheme="https" android:host="www.bilipai.app" android:pathPrefix="/plugins/install" />
                <data android:scheme="https" android:host="plugins.bilipai.app" android:pathPrefix="/plugin/install" />
                <data android:scheme="https" android:host="plugins.bilipai.app" android:pathPrefix="/plugins/install" />
                <data android:scheme="http" android:host="bilipai.app" android:pathPrefix="/plugin/install" />
                <data android:scheme="http" android:host="bilipai.app" android:pathPrefix="/plugins/install" />
                <data android:scheme="http" android:host="www.bilipai.app" android:pathPrefix="/plugin/install" />
                <data android:scheme="http" android:host="www.bilipai.app" android:pathPrefix="/plugins/install" />
                <data android:scheme="http" android:host="plugins.bilipai.app" android:pathPrefix="/plugin/install" />
                <data android:scheme="http" android:host="plugins.bilipai.app" android:pathPrefix="/plugins/install" />
            </intent-filter>
        </activity>

        <activity
            android:name=".MainActivitySplashIcon3D"
            android:exported="false"
            android:enabled="true"
            android:icon="@mipmap/ic_launcher_3d"
            android:roundIcon="@mipmap/ic_launcher_3d"
            android:theme="@style/Theme.PureBiliBili.Splash.Icon3D"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|mnc|colorMode|density|smallestScreenSize|uiMode"
            android:supportsPictureInPicture="true" />

        <activity
