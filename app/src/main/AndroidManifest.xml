            android:exported="false"
            android:enabled="true"
            android:icon="@mipmap/ic_launcher_anime"
            android:roundIcon="@mipmap/ic_launcher_anime"
            android:theme="@style/Theme.PureBiliBili.Splash.Anime"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|mnc|colorMode|density|smallestScreenSize|uiMode"
            android:supportsPictureInPicture="true" />

        <activity
            android:name=".MainActivitySplashHeadphone"
            android:exported="false"
            android:enabled="true"
            android:icon="@mipmap/ic_launcher_headphone"
            android:roundIcon="@mipmap/ic_launcher_headphone"
            android:theme="@style/Theme.PureBiliBili.Splash.Headphone"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|mnc|colorMode|density|smallestScreenSize|uiMode"
            android:supportsPictureInPicture="true" />

        <!-- Yuki 比心少女 (可在设置中切换) -->
        <activity-alias
            android:name=".MainActivityAliasYuki"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:roundIcon="@mipmap/ic_launcher_round"
            android:label="@string/app_name"
            android:targetActivity=".MainActivitySplashYuki">
            <intent-filter android:priority="1">
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <meta-data android:name="android.app.shortcuts" android:resource="@xml/shortcuts" />
        </activity-alias>

        <!-- Anime Girl (蓝发少女) -->
        <activity-alias
            android:name=".MainActivityAliasAnime"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_anime"
            android:roundIcon="@mipmap/ic_launcher_anime"
            android:label="@string/app_name"
            android:targetActivity=".MainActivitySplashAnime">
            <intent-filter android:priority="1">
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <meta-data android:name="android.app.shortcuts" android:resource="@xml/shortcuts" />
        </activity-alias>

        <!-- Headphone Girl (耳机少女) -->
        <activity-alias
            android:name=".MainActivityAliasHeadphone"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_headphone"
            android:roundIcon="@mipmap/ic_launcher_headphone"
            android:label="@string/app_name"
            android:targetActivity=".MainActivitySplashHeadphone">
            <intent-filter android:priority="1">
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- 3D Launcher (默认图标入口) -->
        <activity-alias
            android:name=".MainActivityAlias3DLauncher"
            android:enabled="true"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_3d"
            android:roundIcon="@mipmap/ic_launcher_3d_round"
            android:label="@string/app_name"
            android:targetActivity=".MainActivitySplashIcon3D">
        <intent-filter android:priority="1">
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- 🚀 App Shortcuts -->
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity-alias>

        <!-- 兼容入口：保留旧版默认桌面组件。默认关闭；升级保留旧启用状态时仍可作为兜底入口。 -->
