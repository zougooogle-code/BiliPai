<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 🎀 BiliPai 品牌色 (深色模式也使用相同品牌色) -->
    <color name="bili_pink">#FB7299</color>
    <color name="splash_background">#121212</color>
    
    <!-- 🌙 启动屏主题 (深色模式) - 使用深色背景 -->
    <style name="Theme.PureBiliBili" parent="Theme.SplashScreen.IconBackground">
        <!-- 🎨 Splash Screen 背景色 - 深色模式使用黑色 -->
        <item name="windowSplashScreenBackground">@color/splash_background</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_bilipai</item>
        <item name="windowSplashScreenIconBackgroundColor">@android:color/transparent</item>
        <!-- ⏱️ 图标动画时长 -->
        <item name="windowSplashScreenAnimationDuration">300</item>
        <!-- 🔄 Splash 结束后的主题 -->
        <item name="postSplashScreenTheme">@style/Theme.PureBiliBili.Main</item>
    </style>

    <style name="Theme.PureBiliBili.Splash.Icon3D" parent="Theme.PureBiliBili">
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_3d</item>
    </style>

    <style name="Theme.PureBiliBili.Splash.BiliPai" parent="Theme.PureBiliBili">
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_bilipai</item>
    </style>

    <style name="Theme.PureBiliBili.Splash.BiliPaiPink" parent="Theme.PureBiliBili">
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_bilipai_pink</item>
    </style>

    <style name="Theme.PureBiliBili.Splash.BiliPaiWhite" parent="Theme.PureBiliBili">
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_bilipai_white</item>
    </style>

    <style name="Theme.PureBiliBili.Splash.BiliPaiMonet" parent="Theme.PureBiliBili">
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_bilipai_monet</item>
    </style>

    <style name="Theme.PureBiliBili.Splash.Flat" parent="Theme.PureBiliBili">
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_flat</item>
    </style>

    <style name="Theme.PureBiliBili.Splash.TelegramBlue" parent="Theme.PureBiliBili">
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_telegram_blue</item>
    </style>

    <style name="Theme.PureBiliBili.Splash.TelegramDark" parent="Theme.PureBiliBili">
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_telegram_dark</item>
    </style>

    <style name="Theme.PureBiliBili.Splash.Yuki" parent="Theme.PureBiliBili">
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
    </style>

    <style name="Theme.PureBiliBili.Splash.Anime" parent="Theme.PureBiliBili">
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_anime</item>
    </style>

    <style name="Theme.PureBiliBili.Splash.Headphone" parent="Theme.PureBiliBili">
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_headphone</item>
    </style>
    
    <!-- 主应用主题 (深色模式) -->
    <style name="Theme.PureBiliBili.Main" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">#121212</item>
        <item name="android:colorBackground">#121212</item>
        <item name="android:navigationBarColor">#121212</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>

    <!-- 兼容旧主题名 -->
    <style name="Theme.Purebilibili" parent="Theme.PureBiliBili" />
</resources>
